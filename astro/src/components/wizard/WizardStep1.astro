---
import type { ExtensionMeta } from '@/lib/registry';
import { ARXIV_PROFILES } from '@/lib/arxivProfiles';
import { ARXIV_CATEGORIES } from '@/lib/arxivCategories';

interface Props {
  extensions: ExtensionMeta[];
  locale: 'en' | 'zh';
}
const { extensions, locale } = Astro.props;

const academicProfileKeys = [
  'ai_ml',
  'cv',
  'nlp',
  'robotics',
  'medical_ai',
  'biology',
  'physics',
  'chemistry',
  'mathematics',
  'astrophysics',
] as const;

const t = {
  starterEyebrow: locale === 'zh' ? 'Starter mode' : 'Starter mode',
  starterHead:    locale === 'zh' ? '先选一个简报模式' : 'Choose a briefing mode first',
  starterDesc:    locale === 'zh'
    ? '先用一个最接近你的默认模板启动，再决定是否要在下面继续改来源和顺序。'
    : 'Start from the closest default template first, then refine sources and ordering below if you want more control.',
  academicTitle:  locale === 'zh' ? 'Academic Brief' : 'Academic Brief',
  academicMeta:   locale === 'zh' ? '研究跟踪优先' : 'Research-first',
  academicDesc:   locale === 'zh'
    ? '默认启用 arXiv、Hacker News 和 GitHub Trending，适合学术或研究型工作流。'
    : 'Starts with arXiv, Hacker News, and GitHub Trending for research-heavy workflows.',
  personalTitle:  locale === 'zh' ? 'Daily Personal Brief' : 'Daily Personal Brief',
  personalMeta:   locale === 'zh' ? '日常信息优先' : 'Everyday essentials',
  personalCardDesc: locale === 'zh'
    ? '默认启用天气、Hacker News 和 GitHub Trending，适合轻量的日常晨间简报。'
    : 'Starts with weather, Hacker News, and GitHub Trending for a lighter daily briefing.',
  starterHint:    locale === 'zh'
    ? '这些只是起点。你仍然可以在下面继续调整来源和显示顺序。'
    : 'These are only starting points. You can still change sources and display order below.',
  currentHead:    locale === 'zh' ? '当前已选来源' : 'Current starter sources',
  currentDesc:    locale === 'zh'
    ? '这里会跟着你当前模式和手动增删实时变化。'
    : 'This updates live as you switch modes or manually add/remove sources.',
  domainHead:     locale === 'zh' ? 'Step 0.5 — 选择主研究方向' : 'Step 0.5 — Choose your primary research domain',
  domainDesc:     locale === 'zh'
    ? 'Academic Brief 会先用一个主领域 preset 启动 arXiv；如果还不够，再补充自定义分类和关键词。'
    : 'Academic Brief starts arXiv from one primary domain preset. Add custom categories and keywords if you need more specificity.',
  personalHead:   locale === 'zh' ? 'Daily Personal Brief 会保持更轻量' : 'Daily Personal Brief stays lighter',
  personalPanelDesc: locale === 'zh'
    ? '默认只保留天气、Hacker News 和 GitHub Trending。只有当你需要更多来源时，再展开下面的高级来源选择。'
    : 'It starts with weather, Hacker News, and GitHub Trending. Only open the advanced source picker below if you want to add more.',
  customFocus:    locale === 'zh' ? '自定义方向' : 'Custom focus',
  customFocusDesc: locale === 'zh'
    ? '不套用现成 preset，主要依赖下面的自定义分类和关键词。'
    : 'Skip the preset profiles and drive arXiv mostly with the custom fields below.',
  quickCustomHead: locale === 'zh' ? '快速自定义 arXiv' : 'Quick arXiv customisation',
  quickCustomDesc: locale === 'zh'
    ? '这些会直接同步到后面的完整 arXiv 配置里。想细调更多参数，下一步仍然可以继续改。'
    : 'These sync directly into the full arXiv config later in the wizard. You can still fine-tune more fields in the next step.',
  customCats:     locale === 'zh' ? '自定义分类（如 cs.LG）' : 'Custom categories (e.g. cs.LG)',
  customKws:      locale === 'zh' ? '自定义关键词（must_include）' : 'Custom keywords (must_include)',
  customBoosts:   locale === 'zh' ? '加权关键词（boost_keywords）' : 'Boost keywords',
  addTag:         locale === 'zh' ? '添加' : 'Add',
  noTag:          locale === 'zh' ? '尚未添加' : 'None added',
  advancedHead:   locale === 'zh' ? '高级来源选择与排序' : 'Advanced source selection and ordering',
  advancedDesc:   locale === 'zh'
    ? '只有在你想跳出 starter mode 默认组合时，才需要展开这里。'
    : 'Open this only when you want to move beyond the default starter-mode combination.',
  advancedHint:   locale === 'zh'
    ? '这里的任何改动都会覆盖 starter mode 的默认来源。'
    : 'Any changes here override the starter-mode source defaults.',
  search:     locale === 'zh' ? '搜索扩展...' : 'Search extensions...',
  all:        locale === 'zh' ? '全部' : 'All',
  research:   locale === 'zh' ? '学术' : 'Research',
  tech:       locale === 'zh' ? '技术' : 'Tech',
  career:     locale === 'zh' ? '职业' : 'Career',
  local:      locale === 'zh' ? '本地' : 'Local',
  custom:     locale === 'zh' ? '自定义' : 'Custom',
  orderHead:  locale === 'zh' ? '显示顺序（可拖拽调整）' : 'Display order (drag to reorder)',
  noResults:  locale === 'zh' ? '无匹配结果' : 'No extensions match your search',
};

const categoryLabels = {
  research: t.research,
  tech: t.tech,
  career: t.career,
  local: t.local,
  custom: t.custom,
};
---

<div class="wz-step" data-step="1" aria-hidden="true">
  <section class="wz-card wz-brief-card">
    <div class="wz-step2-section__eyebrow">{t.starterEyebrow}</div>
    <h3>{t.starterHead}</h3>
    <p class="wz-card__desc">{t.starterDesc}</p>

    <div class="wz-brief-mode-grid">
      <button
        type="button"
        class="wz-brief-mode-card"
        data-brief-mode-btn="academic"
        aria-pressed="true"
      >
        <span class="wz-brief-mode-card__title">{t.academicTitle}</span>
        <span class="wz-brief-mode-card__meta">{t.academicMeta}</span>
        <span class="wz-brief-mode-card__desc">{t.academicDesc}</span>
      </button>
      <button
        type="button"
        class="wz-brief-mode-card"
        data-brief-mode-btn="personal"
        aria-pressed="false"
      >
        <span class="wz-brief-mode-card__title">{t.personalTitle}</span>
        <span class="wz-brief-mode-card__meta">{t.personalMeta}</span>
        <span class="wz-brief-mode-card__desc">{t.personalCardDesc}</span>
      </button>
    </div>

    <div class="wz-notice wz-notice--info" style="margin-top:16px">
      {t.starterHint}
    </div>

    <div class="wz-step2-subhead">
      <strong>{t.currentHead}</strong>
      <div class="wz-field__hint">{t.currentDesc}</div>
    </div>
    <div class="wz-brief-selection-summary" data-brief-selection-summary></div>

    <div class="wz-brief-mode-panel" data-brief-mode-panel="academic" hidden={false}>
      <div class="wz-step2-subhead">
        <strong>{t.domainHead}</strong>
        <div class="wz-field__hint">{t.domainDesc}</div>
      </div>

      <div class="wz-profile-grid" data-brief-academic-profiles>
        <label class="wz-profile-card">
          <input type="radio" name="brief_arxiv_preset" value="custom_only" data-arxiv-profile-input />
          <span class="wz-profile-card__name">{t.customFocus}</span>
          <span class="wz-profile-card__summary">{t.customFocusDesc}</span>
        </label>
        {academicProfileKeys.map((key) => {
          const profile = ARXIV_PROFILES[key];
          const pLabel = locale === 'zh' ? profile.labelZh : profile.label;
          const pSummary = locale === 'zh' ? profile.summaryZh : profile.summary;
          return (
            <label class="wz-profile-card">
              <input
                type="radio"
                name="brief_arxiv_preset"
                value={key}
                data-arxiv-profile-input
                checked={key === 'ai_ml'}
              />
              <span class="wz-profile-card__name">{pLabel}</span>
              <span class="wz-profile-card__summary">{pSummary}</span>
            </label>
          );
        })}
      </div>

      <div class="wz-step2-subhead">
        <strong>{t.quickCustomHead}</strong>
        <div class="wz-field__hint">{t.quickCustomDesc}</div>
      </div>

      <div class="wz-field-grid">
        <div class="wz-field wz-field--rich">
          <div class="wz-field__label">{t.customKws}</div>
          <div class="wz-tags" data-sync-key="arxiv-custom-keywords" data-tags="[]">
            <div class="wz-tags__list" data-tags-list>
              <span class="wz-tags__empty">{t.noTag}</span>
            </div>
            <div class="wz-tags__input-row">
              <input type="text" placeholder="e.g. hallucination" class="wz-tags__input" autocomplete="off" />
              <button type="button" class="wz-tags__add" data-tags-add>{t.addTag}</button>
            </div>
          </div>
        </div>

        <div class="wz-field wz-field--rich">
          <div class="wz-field__label">{t.customCats}</div>
          <div class="wz-tags" data-sync-key="arxiv-custom-categories" data-tags="[]">
            <div class="wz-tags__list" data-tags-list>
              <span class="wz-tags__empty">{t.noTag}</span>
            </div>
            <div class="wz-tags__input-row">
              <input type="text" placeholder="e.g. cs.CV" class="wz-tags__input" list="brief-arxiv-cats-datalist" autocomplete="off" />
              <button type="button" class="wz-tags__add" data-tags-add>{t.addTag}</button>
            </div>
          </div>
        </div>
        <datalist id="brief-arxiv-cats-datalist">
          {ARXIV_CATEGORIES.map(cat => (
            <option value={cat.id}>{cat.id} — {cat.name} ({cat.group})</option>
          ))}
        </datalist>

        <div class="wz-field wz-field--rich">
          <div class="wz-field__label">{t.customBoosts}</div>
          <div class="wz-tags" data-sync-key="arxiv-custom-boosts" data-tags="[]">
            <div class="wz-tags__list" data-tags-list>
              <span class="wz-tags__empty">{t.noTag}</span>
            </div>
            <div class="wz-tags__input-row">
              <input type="text" placeholder="e.g. LoRA" class="wz-tags__input" autocomplete="off" />
              <button type="button" class="wz-tags__add" data-tags-add>{t.addTag}</button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="wz-brief-mode-panel" data-brief-mode-panel="personal" hidden={true}>
      <div class="wz-notice wz-notice--info" style="margin-bottom:0">
        <strong>{t.personalHead}</strong>
        <div>{t.personalPanelDesc}</div>
      </div>
    </div>
  </section>

  <details class="wz-brief-advanced">
    <summary class="wz-brief-advanced__summary">
      <span class="wz-brief-advanced__title">{t.advancedHead}</span>
      <span class="wz-brief-advanced__desc">{t.advancedDesc}</span>
    </summary>
    <div class="wz-field__hint" style="margin:0 0 20px">{t.advancedHint}</div>
    <div class="wz-step1-layout">

      <!-- Left: extension browser -->
      <div class="wz-step1-browser">
        <input
          type="search"
          class="wz-search"
          placeholder={t.search}
          data-ext-search
          autocomplete="off"
        />

        <div class="wz-filter-chips" data-ext-filter>
          <button class="wz-chip wz-chip--active" data-cat="all">{t.all}</button>
          <button class="wz-chip" data-cat="research">{t.research}</button>
          <button class="wz-chip" data-cat="tech">{t.tech}</button>
          <button class="wz-chip" data-cat="career">{t.career}</button>
          <button class="wz-chip" data-cat="local">{t.local}</button>
          <button class="wz-chip" data-cat="custom">{t.custom}</button>
        </div>

        <div class="wz-ext-grid" data-ext-grid>
          {extensions.map(ext => {
            const name = locale === 'zh' ? (ext.displayNameZh ?? ext.displayName) : ext.displayName;
            const desc = locale === 'zh' ? (ext.descriptionZh ?? ext.description) : ext.description;
            const categoryLabel = categoryLabels[ext.category];
            return (
              <button
                type="button"
                class="wz-ext-card"
                data-ext-key={ext.key}
                data-ext-cat={ext.category}
                data-ext-tags={ext.tags.join(' ')}
                aria-pressed="false"
              >
                <div class="wz-ext-card__check" aria-hidden="true">✓</div>
                <div class="wz-ext-card__name">{name}</div>
                <p class="wz-ext-card__desc">{desc}</p>
                <div class="wz-ext-card__meta">
                  <span class="wz-label">{categoryLabel}</span>
                  <span class="wz-label wz-label--ghost">{ext.key}</span>
                </div>
              </button>
            );
          })}
          <div class="wz-ext-empty" data-ext-empty hidden>{t.noResults}</div>
        </div>
      </div>

      <!-- Right: selected order -->
      <div class="wz-step1-order">
        <div class="wz-order-head">{t.orderHead}</div>
        <div class="wz-order-list" data-order-list>
          {/* populated by wizardController on init */}
        </div>
      </div>
    </div>
  </details>
</div>
